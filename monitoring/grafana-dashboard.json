{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "gnetId": null,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "gridPos": {
        "h": 3,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "title": "HTTP Requests / sec",
      "type": "graph",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[5m]))",
          "legendFormat": "Total Requests",
          "refId": "A"
        }
      ],
      "yaxes": [
        {
          "format": "short"
        }
      ]
    },
    {
      "gridPos": {
        "h": 3,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "id": 2,
      "title": "Error Rate",
      "type": "graph",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"5xx\"}[5m])) / sum(rate(http_requests_total[5m])) * 100",
          "legendFormat": "Error Rate %",
          "refId": "A"
        }
      ],
      "yaxes": [
        {
          "format": "percent"
        }
      ]
    },
    {
      "gridPos": {
        "h": 3,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "id": 3,
      "title": "P95 Latency",
      "type": "graph",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95",
          "refId": "A"
        }
      ],
      "yaxes": [
        {
          "format": "s"
        }
      ]
    },
    {
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 3
      },
      "id": 4,
      "title": "JVM Memory",
      "type": "graph",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{area=\"heap\"}) / 1024 / 1024",
          "legendFormat": "Heap Used (MB)",
          "refId": "A"
        },
        {
          "expr": "sum(jvm_memory_max_bytes{area=\"heap\"}) / 1024 / 1024",
          "legendFormat": "Heap Max (MB)",
          "refId": "B"
        }
      ],
      "yaxes": [
        {
          "format": "short"
        }
      ]
    },
    {
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 3
      },
      "id": 5,
      "title": "CPU Usage",
      "type": "graph",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(process_cpu_usage[5m])) * 100",
          "legendFormat": "CPU %",
          "refId": "A"
        }
      ],
      "yaxes": [
        {
          "format": "percent"
        }
      ]
    },
    {
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 9
      },
      "id": 6,
      "title": "Database Connections",
      "type": "graph",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(hikaricp_connections_active)",
          "legendFormat": "Active",
          "refId": "A"
        },
        {
          "expr": "sum(hikaricp_connections_max)",
          "legendFormat": "Max",
          "refId": "B"
        }
      ],
      "yaxes": [
        {
          "format": "short"
        }
      ]
    },
    {
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 8,
        "y": 9
      },
      "id": 7,
      "title": "Redis Stream Pending",
      "type": "graph",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(redis_stream_pending_entries)",
          "legendFormat": "Pending Entries",
          "refId": "A"
        }
      ],
      "yaxes": [
        {
          "format": "short"
        }
      ]
    },
    {
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 16,
        "y": 9
      },
      "id": 8,
      "title": "Active Users",
      "type": "graph",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(http_requests_total{endpoint=\"/api/users/profile\"})",
          "legendFormat": "Profile Requests",
          "refId": "A"
        }
      ],
      "yaxes": [
        {
          "format": "short"
        }
      ]
    }
  ],
  "schemaVersion": 16,
  "style": "dark",
  "tags": ["travelmaster", "backend", "monitoring"],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"]
  },
  "timezone": "browser",
  "title": "TravelMaster Backend Dashboard",
  "version": 1
}