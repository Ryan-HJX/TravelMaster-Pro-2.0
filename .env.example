# ── 阿里云百炼 (DashScope) ──────────────────────────
DASHSCOPE_API_KEY=your_dashscope_api_key_here
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_MAIN_MODEL=qwen3-plus
BAILIAN_FLASH_MODEL=qwen3-flash
MODEL_PRIORITY=cloud

# ── 本地降级模型 (Ollama) ────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e2b

# ── 高德地图 MCP ─────────────────────────────────────
AMAP_API_KEY=your_amap_web_service_api_key_here
AMAP_MCP_URL=

# ── 盈米金融 MCP ─────────────────────────────────────
YINGMI_MCP_URL=
YINGMI_API_KEY=your_yingmi_api_key_here

# ── Redis / Worker ───────────────────────────────────
REDIS_URL=redis://localhost:6379/0
ENABLE_STREAM_WORKER=true
JAVA_CALLBACK_BASE_URL=http://localhost:8080/api/internal/ai/tasks
INTERNAL_API_TOKEN=travelmaster-internal-token
EXTERNAL_TIMEOUT_SECONDS=30
